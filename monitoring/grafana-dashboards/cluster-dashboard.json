{
  "dashboard": {
    "id": null,
    "uid": "demo-api-cluster",
    "title": "Demo API - Cluster Health",
    "tags": ["demo-api", "cluster", "kubernetes"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "Pod CPU Usage",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"demo-api\"}[5m])) by (pod)",
            "legendFormat": "{{ pod }}"
          }
        ]
      },
      {
        "title": "Pod Memory Usage (MB)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "sum(container_memory_working_set_bytes{namespace=\"demo-api\"}) by (pod) / 1024 / 1024",
            "legendFormat": "{{ pod }}"
          }
        ]
      },
      {
        "title": "Pod Restart Count",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "sum(kube_pod_container_status_restarts_total{namespace=\"demo-api\"}) by (pod)",
            "legendFormat": "{{ pod }}"
          }
        ]
      },
      {
        "title": "Pod Status",
        "type": "table",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "kube_pod_status_phase{namespace=\"demo-api\"}",
            "legendFormat": "{{ pod }} - {{ phase }}",
            "format": "table",
            "instant": true
          }
        ]
      },
      {
        "title": "Deployment Replicas",
        "type": "stat",
        "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "kube_deployment_status_ready_replicas{namespace=\"demo-api\"}",
            "legendFormat": "Ready"
          }
        ]
      },
      {
        "title": "Desired Replicas",
        "type": "stat",
        "gridPos": { "h": 4, "w": 8, "x": 8, "y": 16 },
        "targets": [
          {
            "expr": "kube_deployment_spec_replicas{namespace=\"demo-api\"}",
            "legendFormat": "Desired"
          }
        ]
      },
      {
        "title": "HPA Current Replicas",
        "type": "stat",
        "gridPos": { "h": 4, "w": 8, "x": 16, "y": 16 },
        "targets": [
          {
            "expr": "kube_horizontalpodautoscaler_status_current_replicas{namespace=\"demo-api\"}",
            "legendFormat": "HPA Current"
          }
        ]
      }
    ]
  }
}
